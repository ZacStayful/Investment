# Anthropic — server-side only, never expose to client
ANTHROPIC_API_KEY=

# Financial Modeling Prep — free tier (250 req/day) is sufficient
FMP_API_KEY=

# Vercel KV (production signal-status persistence). In local dev, the app
# falls back to a JSON file under ./.data/ when these are not set.
# The app also accepts the Upstash-native names UPSTASH_REDIS_REST_URL /
# UPSTASH_REDIS_REST_TOKEN if a Marketplace store injects those instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Phase 2 — monitor (runs monthly)
# Secret that Vercel Cron presents as `Authorization: Bearer <CRON_SECRET>`.
# If unset, the cron route is open (fine for local dev; set it in production).
CRON_SECRET=
# Optional — Slack incoming webhook for Tier 3 / definitive signal alerts.
SLACK_WEBHOOK_URL=
